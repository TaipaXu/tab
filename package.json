{
    "name": "tab",
    "version": "0.6.0",
    "private": true,
    "description": "To make it easier for you to manage browser tab pages",
    "bugs": "https://github.com/TaipaXu/tab/issues",
    "repository": {
        "type": "git",
        "url": "https://github.com/TaipaXu/tab"
    },
    "type": "module",
    "scripts": {
        "dev": "vp build --watch",
        "build": "run-p type-check \"build-only {@}\" --",
        "preview": "vp preview",
        "build-only": "vp build",
        "type-check": "vue-tsc --build",
        "lint": "run-s lint:*",
        "lint:oxlint": "vp lint . --fix",
        "lint:eslint": "eslint \"src/**/*.vue\" \"*.html\" --fix",
        "format": "run-s format:*",
        "format:oxfmt": "vp fmt .",
        "format:templates": "eslint \"src/**/*.vue\" \"*.html\" --fix",
        "prepare": "vp config"
    },
    "dependencies": {
        "@mdi/js": "^7.4.47",
        "vue": "beta",
        "vuetify": "^4.1.2",
        "webextension-polyfill": "^0.12.0"
    },
    "devDependencies": {
        "@tsconfig/node24": "^24.0.4",
        "@types/node": "^24.13.2",
        "@types/webextension-polyfill": "^0.12.5",
        "@typescript-eslint/parser": "^8.61.1",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/tsconfig": "^0.9.1",
        "eslint": "^10.5.0",
        "eslint-plugin-vue": "^10.9.2",
        "jiti": "^2.7.0",
        "npm-run-all2": "^9.0.2",
        "sass": "^1.101.0",
        "typescript": "~6.0.3",
        "vite": "catalog:",
        "vite-plugin-vue-devtools": "^8.1.3",
        "vite-plugin-vuetify": "^2.1.3",
        "vite-plus": "catalog:",
        "vue-eslint-parser": "^10.4.1",
        "vue-tsc": "^3.3.5"
    },
    "engines": {
        "node": "24.17.0"
    },
    "packageManager": "pnpm@11.5.2"
}
